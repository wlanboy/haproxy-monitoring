        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(haproxy_server_active{proxy=~\"$backend\"})",
          "instant": true,
          "legendFormat": "Instanzen gesamt",
          "refId": "A"
        }
      ],
      "title": "Instanzen gesamt",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 12,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(haproxy_server_active{proxy=~\"$backend\"} == 1)",
          "instant": true,
          "legendFormat": "UP",
          "refId": "A"
        }
      ],
      "title": "UP",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 13,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(haproxy_server_active{proxy=~\"$backend\"} == 0) or vector(0)",
          "instant": true,
          "legendFormat": "DOWN",
          "refId": "A"
        }
      ],
      "title": "DOWN",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 14,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(count by (proxy) (haproxy_server_active{proxy=~\"$backend\"}))",
          "instant": true,
          "legendFormat": "Backends",
          "refId": "A"
        }
      ],
      "title": "Backends",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 20,
      "title": "Service Instanzen",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "noValue": "-"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "custom.width",
                "value": 120
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "DOWN", "color": "red", "index": 0 }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "1": { "text": "UP", "color": "green", "index": 1 }
                    }
                  }
                ]
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Backend" },
            "properties": [
              { "id": "custom.width", "value": 220 },
              { "id": "links", "value": [] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Server" },
            "properties": [
              { "id": "custom.width", "value": 180 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Sessions" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "unit", "value": "short" }
            ]
          }
        ]
      },
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 6 },
      "id": 21,
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [
          { "desc": false, "displayName": "Backend" }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "haproxy_server_active{proxy=~\"$backend\"}",
          "instant": true,
          "legendFormat": "{{proxy}} / {{server}}",
          "refId": "Status",
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "haproxy_server_current_sessions{proxy=~\"$backend\"}",
          "instant": true,
          "legendFormat": "{{proxy}} / {{server}}",
          "refId": "Sessions",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "proxy": 0,
              "server": 1,
              "Value #Status": 2,
              "Value #Sessions": 3
            },
            "renameByName": {
              "proxy": "Backend",
              "server": "Server",
              "Value #Status": "Status",
              "Value #Sessions": "Sessions"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [{ "displayName": "Backend", "desc": false }]
          }
        }
      ],
      "title": "Service Registry",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["haproxy", "monitoring"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HAProxy Backend Monitor",
  "uid": "haproxy-backend-monitor",
  "version": 3
}

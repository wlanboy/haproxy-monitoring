        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "id": 22,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "probe_success{job=\"blackbox-http\",instance=~\"$backend\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Probe Ergebnis pro Service (1=UP, 0=DOWN)",
      "type": "timeseries"

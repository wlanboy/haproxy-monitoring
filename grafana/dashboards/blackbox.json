    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "drawStyle": "line",
            "spanNulls": false
          },
          "unit": "s",
          "min": 0
        },
        "overrides": []

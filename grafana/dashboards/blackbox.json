        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "avg by (phase) (probe_http_duration_seconds{job=\"blackbox-http\",instance=~\"$backend\"})",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ],
      "title": "Ø HTTP Probe-Dauer nach Phase (connect, processing, transfer …)",
      "type": "timeseries"

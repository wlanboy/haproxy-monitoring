      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "probe_duration_seconds{job=\"blackbox-http\",instance=~\"$backend\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Probe-Dauer pro Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 30,
      "title": "HTTP Probe Phasen",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },

# URL des HAProxy Stats-CSV-Endpoints
HAPROXY_STATS_URL=http://haproxy:8404/stats;csv

# HTTP-Basic-Auth-Credentials fuer den Stats-Endpoint (leer lassen, wenn
# HAProxy keine "stats auth"-Absicherung konfiguriert hat)
HAPROXY_STATS_USER=
HAPROXY_STATS_PASSWORD=

# Log-Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Zielpfad der generierten Prometheus file_sd-Datei
OUTPUT_FILE=/output/haproxy_backends.json

# Schema fuer die generierten Probe-Target-URLs (http oder https)
PROBE_SCHEME=http

# Pfad fuer die generierten Probe-Target-URLs
PROBE_PATH=/

# Wartezeit in Sekunden zwischen Verbindungsversuchen
RETRY_INTERVAL=2

# Maximale Anzahl an Verbindungsversuchen
MAX_RETRIES=30
